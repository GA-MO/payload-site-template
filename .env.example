# Copy to .env for local development. Fill in real values locally.
# NEVER put production credentials here or in .env on a dev machine —
# prod secrets live only in the deploy platform, and prod migrations run in
# CI/deploy, never from a dev machine. Seed/import scripts refuse to run
# against a non-local DATABASE_URI (see scripts/lib/assert-local-db.ts).

PAYLOAD_SECRET=replace-with-a-long-random-string
DATABASE_URI=postgres://app:app@127.0.0.1:5433/app
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
