{
  "name": "payload-site-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "npm run check:migrations && next build",
    "start": "next start",
    "lint": "eslint",
    "payload": "node --env-file=.env --import tsx node_modules/.bin/payload",
    "migrate": "npm run payload -- migrate",
    "migrate:create": "npm run payload -- migrate:create",
    "migrate:status": "npm run payload -- migrate:status",
    "check:migrations": "node --import tsx scripts/check-migrations.ts",
    "reprocess:media": "node --env-file=.env --import tsx scripts/reprocess-media.ts",
    "clean:media-orphans": "node --env-file=.env --import tsx scripts/clean-orphan-media.ts",
    "find:unused-media": "node --env-file=.env --import tsx scripts/find-unused-media.ts",
    "test": "vitest run --project unit",
    "test:storybook": "vitest run --project storybook",
    "test:smoke": "bash scripts/test-template.sh",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@payloadcms/db-postgres": "^3.85.0",
    "@payloadcms/next": "^3.85.0",
    "@payloadcms/richtext-lexical": "^3.85.0",
    "@payloadcms/ui": "^3.85.0",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.21",
    "github-slugger": "^2.0.0",
    "graphql": "^16.14.0",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "next": "16.2.6",
    "payload": "^3.85.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "react-scroll": "^1.9.3",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "^10.4.1",
    "@storybook/nextjs-vite": "^10.4.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-scroll": "^1.8.10",
    "@vitest/browser-playwright": "^4.1.7",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "eslint-plugin-storybook": "^10.4.1",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "storybook": "^10.4.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
